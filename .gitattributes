# 1. Mark C header files or large C boilerplate as 'documentation' or 'vendored' 
# so they don't count towards the language percentage
*.h linguist-documentation
libbpf/** linguist-vendored

# 2. Explicitly tell GitHub these are the 'main' detectable languages
*.go linguist-detectable=true
*.sh linguist-detectable=true

# 3. If you have a specific folder for your Go code, ensure it's not being ignored
# e.g., if your go code is in /cmd or /pkg
cmd/** linguist-detectable=true
