# Generated files — excluded from language stats
*_bpfel.go linguist-generated=true
*_bpfeb.go linguist-generated=true
go.sum linguist-generated=true

# Documentation — excluded from language stats
*.md linguist-documentation=true

# Language overrides
kernel/*.bpf.c linguist-language=C
kernel/*.h     linguist-language=C

# Line endings
* text=auto
*.go text eol=lf
*.c  text eol=lf
*.h  text eol=lf
*.sh text eol=lf
*.yml text eol=lf
